# ============================================================
# EMPLOI CONCOURS CI — Variables d'environnement
# Copier ce fichier en `.env` et remplir les valeurs.
# Le fichier `.env` ne doit JAMAIS être commité (cf. .gitignore).
# ============================================================

# ----- SUPABASE -----
# URL du projet (Settings → API)
SUPABASE_URL=
# Clé service_role — UNIQUEMENT côté serveur (collecteur, webhooks).
# NE JAMAIS l'exposer au frontend ni la committer.
SUPABASE_SERVICE_ROLE_KEY=

# Clé anon — la SEULE autorisée côté frontend (préfixe VITE_ pour Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=https://plateforme-pi.vercel.app

# ----- COLLECTEUR -----
# Fréquence cron (défaut : toutes les 6h). 1x/jour à 6h : 0 6 * * *
COLLECT_CRON=0 */6 * * *

# ----- RESEND (envoi emails : lundi et jeudi) -----
RESEND_API_KEY=
RESEND_FROM="Emploi Concours CI <alertes@emploi-concours.ci>"
# false pour envoyer de VRAIS emails avec Resend
DRY_RUN_EMAILS=true

# Planning des emails candidats : lundi et jeudi à 8h (Africa/Abidjan)
EMAIL_DIGEST_CRON=0 8 * * 1,4

# ----- GENIUSPAY (paiements) -----
# Clé API GeniusPay (obtenue depuis https://geniuspay.ci/dashboard)
GENIUSPAY_API_KEY=
# Clé API secrète GeniusPay
GENIUSPAY_API_SECRET=
# Secret webhook GeniusPay (whsec_...)
GENIUSPAY_WEBHOOK_SECRET=

# ----- MONITORING -----
SENTRY_DSN=
